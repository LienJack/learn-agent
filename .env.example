# DEV / Hashnode cross-posting through crier.
# Copy these into your local .env or shell profile. Never commit real tokens.
CRIER_DEVTO_API_KEY=replace-with-dev-api-key
CRIER_HASHNODE_API_KEY=replace-with-hashnode-token-or-token-publication-id

# Medium no longer issues new integration tokens for new integrations.
# Fill this only if your Medium account already has an existing token.
CRIER_MEDIUM_API_KEY=replace-with-existing-medium-integration-token

# Optional: pin a different crier release.
CRIER_VERSION=2.0.2

# Optional image handling for DEV / Hashnode cross-posts.
# Use one of these when articles contain local Markdown images like ./assets/foo.png.
# DEVTO_IMAGE_UPLOAD_COOKIE uploads through DEV's editor image endpoint with your browser login cookie.
DEVTO_IMAGE_UPLOAD_COOKIE=
DEVTO_IMAGE_UPLOAD_CSRF_TOKEN=

# Or provide a custom uploader. The command receives:
#   $PUBLISH_IMAGE_FILE, $PUBLISH_IMAGE_HASH, $PUBLISH_IMAGE_SOURCE
# It must print the uploaded public image URL to stdout.
PUBLISH_IMAGE_UPLOAD_COMMAND=

# Or, if images are already hosted under a public directory, rewrite ./assets/foo.png against this base URL.
PUBLISH_IMAGE_BASE_URL=
