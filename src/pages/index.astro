---
import BaseHead from '../components/BaseHead.astro';
import Header from '../components/Header.astro';
import HomePage from '../components/home/HomePage';
import VercelAnalytics from '../components/VercelAnalytics.astro';
import { DEFAULT_LOCALE } from '../i18n/config';
import { getHtmlLang, getMessages } from '../i18n/messages';
import { localizePath } from '../i18n/utils';
import { PERSONAL_IDENTITY } from '../seo/identity';
import { buildPersonJsonLd } from '../seo/metadata';

const locale = DEFAULT_LOCALE;
const messages = getMessages(locale);
const personJsonLd = buildPersonJsonLd({ locale, path: localizePath(locale, '/') }, Astro.site);
---

<!doctype html>
<html lang={getHtmlLang(locale)}>
	<head>
		<BaseHead
			title={messages.meta.homeTitle}
			description={messages.site.description}
			image={PERSONAL_IDENTITY.shareImagePath}
			imageAlt={PERSONAL_IDENTITY.shareImageAlt}
			locale={locale}
			structuredData={personJsonLd}
		/>
	</head>
	<body>
		<Header />
		<main class="page-shell-wide">
			<HomePage
				siteTitle={messages.site.title}
				copy={messages.home}
				blogHref={localizePath(locale, '/blog')}
				recommendedHref={localizePath(locale, '/blog/AI/3.ClaudeCode源码解析')}
				harnessHref={localizePath(locale, '/blog/AI/build-harness')}
				client:load
			/>
		</main>
		<VercelAnalytics />
	</body>
</html>
