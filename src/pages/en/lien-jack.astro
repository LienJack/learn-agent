---
import BaseHead from '../../components/BaseHead.astro';
import AboutPage from '../../components/about/AboutPage.astro';
import Footer from '../../components/Footer.astro';
import Header from '../../components/Header.astro';
import VercelAnalytics from '../../components/VercelAnalytics.astro';
import { getHtmlLang, getMessages } from '../../i18n/messages';
import {
	getIdentityDescription,
	getIdentityJobTitle,
	getIdentityPath,
	PERSONAL_IDENTITY,
} from '../../seo/identity';
import { buildPersonJsonLd } from '../../seo/metadata';

const locale = 'en';
const messages = getMessages(locale);
const identityPath = getIdentityPath(locale);
const personJsonLd = buildPersonJsonLd({ locale, path: identityPath }, Astro.site);
---

<!doctype html>
<html lang={getHtmlLang(locale)}>
	<head>
		<BaseHead
			title={`${PERSONAL_IDENTITY.name} - ${getIdentityJobTitle(locale)}`}
			description={getIdentityDescription(locale)}
			image={PERSONAL_IDENTITY.shareImagePath}
			imageAlt={PERSONAL_IDENTITY.shareImageAlt}
			locale={locale}
			canonicalPath={identityPath}
			structuredData={personJsonLd}
		/>
	</head>
	<body>
		<Header />
		<main class="page-shell-wide">
			<AboutPage copy={messages.about} />
		</main>
		<Footer />
		<VercelAnalytics />
	</body>
</html>
