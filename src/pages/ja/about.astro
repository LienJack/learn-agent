---
import BaseHead from '../../components/BaseHead.astro';
import AboutPage from '../../components/about/AboutPage.astro';
import Footer from '../../components/Footer.astro';
import Header from '../../components/Header.astro';
import VercelAnalytics from '../../components/VercelAnalytics.astro';
import { getHtmlLang, getMessages } from '../../i18n/messages';
import { PERSONAL_IDENTITY } from '../../seo/identity';
import { buildPersonJsonLd } from '../../seo/metadata';

const locale = 'ja';
const messages = getMessages(locale);
const personJsonLd = buildPersonJsonLd({ locale, path: '/ja/about' }, Astro.site);
---

<!doctype html>
<html lang={getHtmlLang(locale)}>
	<head>
		<BaseHead
			title={messages.meta.aboutTitle}
			description={messages.meta.aboutDescription}
			image={PERSONAL_IDENTITY.shareImagePath}
			imageAlt={PERSONAL_IDENTITY.shareImageAlt}
			locale={locale}
			structuredData={personJsonLd}
		/>
	</head>
	<body class="locale-ja">
		<Header />
		<main class="page-shell-wide">
			<AboutPage copy={messages.about} />
		</main>
		<Footer />
		<VercelAnalytics />
	</body>
</html>
