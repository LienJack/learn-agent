---
import '../styles/global.css';
import type { ImageMetadata } from 'astro';
import { Font } from 'astro:assets';
import { DEFAULT_LOCALE, type Locale } from '../i18n/config';
import { getHtmlLang, getMessages, getOgLocale } from '../i18n/messages';
import {
	DEFAULT_SHARE_IMAGE_ALT,
	buildCanonicalUrl,
	buildDefaultAlternates,
	resolveImageUrl,
	serializeJsonLd,
	type AlternateLink,
	type JsonLdObject,
	type SeoPageType,
} from '../seo/metadata';

interface Props {
	title: string;
	description: string;
	image?: ImageMetadata | string;
	imageAlt?: string;
	locale?: Locale;
	pageType?: SeoPageType;
	canonicalPath?: string;
	alternates?: AlternateLink[];
	structuredData?: JsonLdObject | JsonLdObject[];
}

const {
	title,
	description,
	image,
	imageAlt = DEFAULT_SHARE_IMAGE_ALT,
	locale = DEFAULT_LOCALE,
	pageType = 'website',
	canonicalPath = Astro.url.pathname,
	alternates,
	structuredData,
} = Astro.props;
const messages = getMessages(locale);
const siteTitle = messages.site.title;
const pageTitle = title === siteTitle ? siteTitle : `${title} · ${siteTitle}`;
const pageDescription = description || messages.site.description;
const canonicalURL = buildCanonicalUrl(canonicalPath, Astro.site);
const socialImageURL = resolveImageUrl(image, Astro.site);
const socialImageAlt = imageAlt || DEFAULT_SHARE_IMAGE_ALT;
const alternateLinks = alternates ?? buildDefaultAlternates(locale, canonicalPath, Astro.site);
const ogType = pageType === 'article' ? 'article' : 'website';
const jsonLdBlocks = structuredData
	? Array.isArray(structuredData)
		? structuredData
		: [structuredData]
	: [];
---

<meta charset="utf-8" />
<meta name="viewport" content="width=device-width,initial-scale=1" />
<meta http-equiv="content-language" content={getHtmlLang(locale)} />
<link rel="icon" type="image/svg+xml" href="/favicon.svg" />
<link rel="icon" href="/favicon.ico" />
<link rel="sitemap" href="/sitemap-index.xml" />
<link rel="alternate" type="text/markdown" href="/llms.txt" title="LLM summary for Learn Agent" />
<meta name="generator" content={Astro.generator} />

<Font cssVariable="--font-atkinson" preload />

<link rel="canonical" href={canonicalURL} />
{alternateLinks.map((item) => <link rel="alternate" hreflang={item.hreflang} href={item.href} />)}

<title>{pageTitle}</title>
<meta name="title" content={pageTitle} />
<meta name="description" content={pageDescription} />

<meta property="og:type" content={ogType} />
<meta property="og:url" content={canonicalURL} />
<meta property="og:site_name" content={siteTitle} />
<meta property="og:locale" content={getOgLocale(locale)} />
<meta property="og:title" content={pageTitle} />
<meta property="og:description" content={pageDescription} />
<meta property="og:image" content={socialImageURL} />
<meta property="og:image:alt" content={socialImageAlt} />

<meta property="twitter:card" content="summary_large_image" />
<meta property="twitter:url" content={canonicalURL} />
<meta property="twitter:title" content={pageTitle} />
<meta property="twitter:description" content={pageDescription} />
<meta property="twitter:image" content={socialImageURL} />
<meta property="twitter:image:alt" content={socialImageAlt} />
{jsonLdBlocks.map((item) => <script is:inline type="application/ld+json" set:html={serializeJsonLd(item)} />)}
