---
import { LOCALES, LOCALE_LABELS } from '../i18n/config';
import { getMessages } from '../i18n/messages';
import { getLocaleFromPathname, getSwitchLocalePath, localizePath } from '../i18n/utils';
import HeaderLink from './HeaderLink.astro';

const locale = getLocaleFromPathname(Astro.url.pathname);
const messages = getMessages(locale);
const currentPath = Astro.url.pathname;
---

<header class="site-header">
	<nav class="site-header-inner" aria-label={messages.header.ariaLabel}>
		<a class="site-brand" href={localizePath(locale, '/')}>
			<span class="site-brand-title">{messages.site.title}</span>
			<span class="site-brand-tagline">{messages.site.tagline}</span>
		</a>
		<div class="site-nav">
			<HeaderLink href={localizePath(locale, '/')}>{messages.header.home}</HeaderLink>
			<HeaderLink href={localizePath(locale, '/blog')}>{messages.header.blog}</HeaderLink>
			<HeaderLink href={localizePath(locale, '/about')}>{messages.header.about}</HeaderLink>
		</div>
		<div class="site-header-actions">
			<details class="site-locale-switcher">
				<summary
					class="site-locale-trigger"
					aria-label={messages.header.languageSwitcherLabel}
				>
					<svg
						class="site-locale-icon"
						viewBox="0 0 24 24"
						aria-hidden="true"
						xmlns="http://www.w3.org/2000/svg"
					>
						<circle cx="12" cy="12" r="8.5" />
						<path d="M3.5 12h17" />
						<path d="M12 3.5c2.7 2.3 4.3 5.2 4.3 8.5S14.7 18.2 12 20.5c-2.7-2.3-4.3-5.2-4.3-8.5S9.3 5.8 12 3.5Z" />
					</svg>
					<span class="sr-only">{messages.header.languageSwitcherLabel}</span>
				</summary>
				<div class="site-locale-menu">
					{
						LOCALES.map((targetLocale) => (
							<a
								href={getSwitchLocalePath(targetLocale, currentPath)}
								class:list={['site-locale-link', { active: targetLocale === locale }]}
								aria-current={targetLocale === locale ? 'true' : undefined}
							>
								<span class="site-locale-code">{targetLocale.toUpperCase()}</span>
								<span>{LOCALE_LABELS[targetLocale]}</span>
							</a>
						))
					}
				</div>
			</details>
			<a
				class="site-header-icon-link"
				href="https://github.com/LienJack/learn-agent"
				target="_blank"
				rel="noreferrer"
				aria-label={messages.header.githubLabel}
			>
				<svg
					class="site-header-icon"
					viewBox="0 0 24 24"
					aria-hidden="true"
					xmlns="http://www.w3.org/2000/svg"
				>
					<path d="M12 2C6.48 2 2 6.58 2 12.22c0 4.5 2.87 8.32 6.84 9.67.5.1.68-.22.68-.49 0-.24-.01-1.05-.01-1.91-2.78.62-3.37-1.21-3.37-1.21-.45-1.18-1.11-1.49-1.11-1.49-.91-.64.07-.63.07-.63 1 .07 1.53 1.06 1.53 1.06.9 1.57 2.35 1.12 2.92.86.09-.67.35-1.12.63-1.37-2.22-.26-4.55-1.14-4.55-5.09 0-1.12.39-2.03 1.03-2.75-.1-.26-.45-1.31.1-2.73 0 0 .84-.28 2.75 1.05A9.35 9.35 0 0 1 12 6.92c.85 0 1.71.12 2.51.36 1.91-1.33 2.75-1.05 2.75-1.05.55 1.42.2 2.47.1 2.73.64.72 1.03 1.63 1.03 2.75 0 3.96-2.34 4.82-4.57 5.08.36.32.68.94.68 1.9 0 1.37-.01 2.47-.01 2.8 0 .27.18.6.69.49A10.24 10.24 0 0 0 22 12.22C22 6.58 17.52 2 12 2Z" />
				</svg>
				<span class="sr-only">{messages.header.githubLabel}</span>
			</a>
		</div>
	</nav>
</header>

<script>
	const localeSwitchers = document.querySelectorAll('.site-locale-switcher');

	localeSwitchers.forEach((switcher) => {
		if (!(switcher instanceof HTMLDetailsElement) || switcher.dataset.bound === 'true') {
			return;
		}

		switcher.dataset.bound = 'true';

		document.addEventListener('click', (event) => {
			if (!switcher.open) {
				return;
			}

			const target = event.target;
			if (target instanceof Node && !switcher.contains(target)) {
				switcher.open = false;
			}
		});

		switcher.addEventListener('keydown', (event) => {
			if (event.key === 'Escape') {
				switcher.open = false;
			}
		});
	});
</script>
