---
import { Image } from 'astro:assets';
import type { CollectionEntry } from 'astro:content';
import BaseHead from '../../components/BaseHead.astro';
import Header from '../../components/Header.astro';
import {
	buildBlogGroupCards,
	type BlogGroupPageData,
	type BlogSeriesPageData,
} from './blog-index';
import { LOCALES, LOCALE_LABELS, type Locale } from '../../i18n/config';
import { getHtmlLang } from '../../i18n/messages';
import { localizePath } from '../../i18n/utils';
import { getMessages } from '../../i18n/messages';
import { getPostSlug } from '../../content/blog/utils';
import { buildBlogCollectionSeoData } from '../../seo/blog';

type Props = {
	locale: Locale;
	posts: CollectionEntry<'blog'>[];
	title: string;
	description: string;
	group?: BlogGroupPageData;
	series?: BlogSeriesPageData;
};

const listingCopy = {
	zh: {
		groupOverview: 'Group Overview',
		postCountShort: (count: number) => `${count} 篇`,
		postCountLong: (count: number) => `${count} 篇文章`,
		backToGroup: (groupTitle: string | undefined) => `返回 ${groupTitle ?? '文章列表'}`,
		seriesKicker: '阅读路径',
		startReading: '开始阅读',
		tocLabel: '目录',
		tocSummary: '按顺序读下去，会从模型原理一路走到 Agent 与 Harness 的工程视角。',
		guideBadge: '导读',
		groupCta: '进入专栏',
		emptyGroup: '这个专栏入口已经准备好，后续项目系列会继续补进来。',
		emptySeries: '这个系列的目录已经预留出来了，后续内容会继续补进来。',
	},
	en: {
		groupOverview: 'Group Overview',
		postCountShort: (count: number) => `${count} posts`,
		postCountLong: (count: number) => `${count} articles`,
		backToGroup: (groupTitle: string | undefined) => `Back to ${groupTitle ?? 'articles'}`,
		seriesKicker: 'Reading path',
		startReading: 'Start reading',
		tocLabel: 'Contents',
		tocSummary:
			'Read in order to move from model fundamentals into an engineering view of agents and harnesses.',
		guideBadge: 'Guide',
		groupCta: 'Open group',
		emptyGroup: 'This topic shelf is ready. Project series will be added over time.',
		emptySeries: 'This series outline is ready. More articles will be added over time.',
	},
	ja: {
		groupOverview: 'グループ概要',
		postCountShort: (count: number) => `${count} 本`,
		postCountLong: (count: number) => `${count} 本の記事`,
		backToGroup: (groupTitle: string | undefined) => `${groupTitle ?? '記事一覧'} へ戻る`,
		seriesKicker: '読む順番',
		startReading: '読み始める',
		tocLabel: '目次',
		tocSummary:
			'順番に読むと、モデルの仕組みから Agent と Harness の工学的な見方までたどれます。',
		guideBadge: 'ガイド',
		groupCta: '棚を開く',
		emptyGroup: 'この棚の入口は準備済みです。プロジェクトシリーズを順次追加します。',
		emptySeries: 'このシリーズの目次は準備中です。後続の記事を追加していきます。',
	},
} satisfies Record<
	Locale,
	{
		groupOverview: string;
		postCountShort: (count: number) => string;
		postCountLong: (count: number) => string;
		backToGroup: (groupTitle: string | undefined) => string;
		seriesKicker: string;
		startReading: string;
		tocLabel: string;
		tocSummary: string;
		guideBadge: string;
		groupCta: string;
		emptyGroup: string;
		emptySeries: string;
	}
>;

const { locale, posts, title, description, group, series } = Astro.props;
const messages = getMessages(locale);
const copy = listingCopy[locale];
const groupedCards = await buildBlogGroupCards(posts, locale);
const currentGroup = series?.group ?? group ?? null;
const currentSeries = series ?? null;
const currentSeriesGuidePost = currentSeries?.featuredPost ?? currentSeries?.posts[0] ?? null;
const collectionPath = currentSeries
	? `/blog/${currentSeries.path}`
	: currentGroup
		? `/blog/${currentGroup.path}`
		: '/blog';
const collectionImage = currentSeries?.cover ?? currentGroup?.cover ?? groupedCards[0]?.cover;
const collectionItems = currentSeries
	? currentSeries.posts.map((post) => ({
			name: post.data.title,
			path: localizePath(locale, `/blog/${getPostSlug(post)}`),
			description: post.data.description,
		}))
	: currentGroup
		? currentGroup.series.map((item) => ({
				name: item.title,
				path: localizePath(locale, `/blog/${item.path}`),
				description: item.description,
			}))
		: groupedCards.map((item) => ({
				name: item.title,
				path: localizePath(locale, `/blog/${item.path}`),
				description: item.description,
			}));
const seo = buildBlogCollectionSeoData({
	title,
	description,
	path: collectionPath,
	locale,
	site: Astro.site,
	image: collectionImage,
	group: currentGroup,
	series: currentSeries,
	items: collectionItems,
});
---

<!doctype html>
<html lang={getHtmlLang(locale)}>
	<head>
		<BaseHead
			title={title}
			description={description}
			image={collectionImage}
			locale={locale}
			pageType="collection"
			canonicalPath={seo.canonicalPath}
			alternates={seo.alternates}
			structuredData={seo.structuredData}
		/>
	</head>
	<body class:list={['blog-listing-page', { 'blog-series-route-page': currentSeries }]}>
		<Header />
		<main class="page-shell-wide">
			{
				!currentSeries && (
					<section class="page-intro">
						<p class="page-eyebrow">Group</p>
						<h1>{title}</h1>
						<p class="page-lead">{description}</p>
						<div class="archive-language-links" aria-label={messages.blog.browseByLanguage}>
							{
								LOCALES.map((targetLocale) => (
									<a
										href={localizePath(targetLocale, currentGroup ? `/blog/${currentGroup.slug}` : '/blog')}
										class:list={['archive-language-link', { active: targetLocale === locale }]}
										aria-current={targetLocale === locale ? 'page' : undefined}
									>
										{LOCALE_LABELS[targetLocale]}
									</a>
								))
							}
						</div>
					</section>
				)
			}

			{
				currentGroup && !currentSeries && (
					<section class="blog-groups">
						<article class="blog-group-card">
							<div class="blog-group-hero">
								<div class="blog-group-copy">
									<p class="blog-group-kicker">{copy.groupOverview}</p>
									<h2>{currentGroup.title}</h2>
									{currentGroup.alias && <p class="blog-group-alias">{currentGroup.alias}</p>}
									<p class="blog-group-description">{currentGroup.description}</p>
								</div>
								<div class="blog-group-cover">
									{
										typeof currentGroup.cover === 'string' ? (
											<img src={currentGroup.cover} alt="" loading="lazy" decoding="async" width="900" height="520" />
										) : (
											<Image width={900} height={520} src={currentGroup.cover} alt="" />
										)
									}
								</div>
							</div>
							{
								currentGroup.series.length > 0 ? (
									<ul class="blog-series-grid">
										{
											currentGroup.series.map((item) => (
												<li class="blog-series-card">
													<a class="blog-series-link" href={localizePath(locale, `/blog/${item.path}`)}>
														<div class="blog-series-cover">
															{
																typeof item.cover === 'string' ? (
																	<img src={item.cover} alt="" loading="lazy" decoding="async" width="640" height="420" />
																) : (
																	<Image width={640} height={420} src={item.cover} alt="" />
																)
															}
														</div>
														<div class="blog-series-body">
															<p class="blog-series-index">{copy.postCountShort(item.postCount)}</p>
															<h3 class="blog-series-title">{item.title}</h3>
															<p class="blog-series-description">{item.description}</p>
														</div>
													</a>
												</li>
											))
										}
									</ul>
								) : (
									<p class="blog-group-empty">{copy.emptyGroup}</p>
								)
							}
						</article>
					</section>
				)
			}

			{
				currentSeries && (
					<section class="series-posts-shell series-posts-shell-editorial">
						<div class="series-context-strip">
							<a class="series-context-link" href={localizePath(locale, `/blog/${currentGroup?.slug}`)}>
								{copy.backToGroup(currentGroup?.title)}
							</a>
							<span class="series-context-divider">/</span>
							<span class="series-context-current">{currentSeries.title}</span>
						</div>

						<div class="series-overview-card">
							<div class="series-overview-cover">
								{
									typeof currentSeries.cover === 'string' ? (
										<img src={currentSeries.cover} alt="" loading="eager" decoding="async" width="900" height="520" />
									) : (
										<Image width={900} height={520} src={currentSeries.cover} alt="" />
									)
								}
							</div>
							<div class="series-overview-copy">
								<p class="series-overview-kicker">{copy.seriesKicker}</p>
								<div class="series-overview-heading">
									<p class="blog-series-index">{copy.postCountLong(currentSeries.postCount)}</p>
									<h1 class:list={['series-overview-title', { 'is-short-series-title': currentSeries.title.length <= 18 }]}>
										{currentSeries.title}
									</h1>
								</div>
								{currentSeries.alias && <p class="blog-group-alias">{currentSeries.alias}</p>}
								<p class="blog-group-description">{currentSeries.description}</p>
								{
									currentSeriesGuidePost && (
										<a
											class="series-guide-link"
											href={localizePath(locale, `/blog/${getPostSlug(currentSeriesGuidePost)}`)}
										>
											<span class="series-guide-title">{copy.startReading}</span>
										</a>
									)
								}
							</div>
						</div>

						<div class="series-posts-intro">
							<p class="series-posts-label">{copy.tocLabel}</p>
							<p class="series-posts-summary">{copy.tocSummary}</p>
						</div>

						<ol class="series-post-list">
							{
								currentSeries.posts.map((post, index) => (
									<li class:list={['series-post-item', { 'is-guide': index === 0 }]}>
										<a class="series-post-link" href={localizePath(locale, `/blog/${getPostSlug(post)}`)}>
											<span class="series-post-step">{String(index + 1).padStart(2, '0')}</span>
											<span class="series-post-main">
												<span class="series-post-title-row">
													<span class="series-post-title">{post.data.title}</span>
													{
														index === 0 && (
															<span class="series-post-badge">{copy.guideBadge}</span>
														)
													}
												</span>
												<span class="series-post-description">{post.data.description}</span>
											</span>
										</a>
									</li>
								))
							}
							{
								currentSeries.posts.length === 0 && (
									<li class="series-post-empty">
										{copy.emptySeries}
									</li>
								)
							}
						</ol>
					</section>
				)
			}

			{
				!currentGroup && (
					<section class="blog-groups">
						{
							groupedCards.map((item) => (
								<article class="blog-group-card">
									<div class="blog-group-hero">
										<div class="blog-group-copy">
											<p class="blog-group-kicker">Group</p>
											<h2>{item.title}</h2>
											<p class="blog-group-description">{item.description}</p>
											<a class="blog-group-entry-link" href={localizePath(locale, `/blog/${item.path}`)}>
												{copy.groupCta}
											</a>
										</div>
										<div class="blog-group-cover">
											{
												typeof item.cover === 'string' ? (
													<img src={item.cover} alt="" loading="lazy" decoding="async" width="900" height="520" />
												) : (
													<Image width={900} height={520} src={item.cover} alt="" />
												)
											}
										</div>
									</div>
								</article>
							))
						}
					</section>
				)
			}
		</main>
	</body>
</html>
