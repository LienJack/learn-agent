flowchart TB
  LOG["Session Log\n不可变事件事实源"] --> FOLD["State Reducer\n折叠事件"]
  FOLD --> ST["State\n当前任务现场"]
  ST --> CP["Context Projector\n选择、压缩、隔离、排序"]
  MEM["Memory Store\n跨任务经验"] --> CP
  DOC["Project Docs / Index\n外部知识"] --> CP
  CP --> INPUT["Model Input\n本轮上下文"]
  INPUT --> MODEL["Model Provider\n模型事件"]
  MODEL --> LOOP["Runtime Decision\n继续/审批/执行/结束"]
  LOOP --> LOG

  LOG:::hot
  CP:::hot

  classDef hot fill:#fff3b0,stroke:#111,stroke-width:2px,color:#111;
