flowchart LR
  M["Model Output\n工具意图"] --> V["Validate\n参数校验"]
  V --> P["Policy\n权限判断"]
  P --> X["Execute\n受控执行"]
  X --> R["Result\n真实结果"]
  R --> O["Observation\n回填给模型"]
  O --> S["State\n更新现场"]

  P -->|deny / ask| U["User / Rule\n拒绝或审批"]
  U --> O

  M:::cold
  P:::hot
  O:::hot

  classDef hot fill:#fff3b0,stroke:#111,stroke-width:2px,color:#111;
  classDef cold fill:#e8f3ff,stroke:#111,stroke-width:1.5px,color:#111;
