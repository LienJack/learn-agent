flowchart TB
  A["Install\n文件落地"] --> B["Verify\n来源/版本/校验"]
  B --> C{"Trust\n用户/组织策略"}
  C -- "不信任" --> X["Disabled\n不能贡献能力"]
  C -- "信任" --> D["Load Manifest\nPlugin Host"]
  D --> E["Contribute\nprovider/tool/skill/hook"]
  E --> F["Capability Catalog\n候选能力"]
  F --> G{"Discovery\n任务/路径/预算/权限"}
  G -- "不可见" --> H["Hidden\n本轮不进入 prompt"]
  G -- "可见" --> I["Visible Set\n模型可提出 intent"]
  I --> J{"Permission Gate\n参数/风险/审批"}
  J -- "拒绝" --> K["Denied Event\n写入日志"]
  J -- "通过" --> L["Tool Runtime\n受控执行"]

  C:::hot
  G:::hot
  J:::hot

  classDef hot fill:#fff3b0,stroke:#111,stroke-width:2px,color:#111;
