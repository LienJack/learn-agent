  E1 --> J
  E2 --> I
  E3 --> P
  E4 --> X
  E5 --> O
  E6 --> V

  G --> C --> J --> I --> P --> X --> O --> V

  classDef hot fill:#fff3c4,stroke:#d6a700,color:#222;
