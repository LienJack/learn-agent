flowchart LR
  U["用户目标\n修复测试失败"] --> C["Core Runtime\n组织一轮请求"]
  C --> P["Provider Runtime\n调用真实模型"]
  P --> S["Streaming Adapter\n归一化事件"]
  S --> E["ModelEvent\ntext / reasoning / finish / usage / error"]
  S --> I["ToolIntent\n只描述动作"]
  E --> C
  I --> C
  C --> L["Event Log\n记录事实"]
  C --> T["Tool Pipeline\n验证 / 权限 / 执行"]
  T --> O["Observation\n结果回填"]
  O --> C

  P -. "不能执行工具" .-> T
  I:::hot
  C:::hot
  T:::hot

  classDef hot fill:#fff3b0,stroke:#111,stroke-width:2px,color:#111;
