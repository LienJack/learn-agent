flowchart TD
  E["发生错误"] --> K{"错误来自哪里？"}
  K -->|HTTP / SDK / stream| PE["ProviderError\n模型调用层"]
  K -->|tool intent parse| IE["IntentError\n意图解析层"]
  K -->|schema / policy| VE["ValidationError\n校验层"]
  K -->|用户拒绝 / 权限| AE["ApprovalEvent\n权限层"]
  K -->|真实工具失败| TE["ToolError\n执行层"]

  PE --> R1["重试 / 降级 / 结束本轮"]
  IE --> R2["要求模型重发 intent"]
  VE --> R3["拒绝并回填原因"]
  AE --> R4["等待用户或记录拒绝"]
  TE --> R5["生成 observation"]

  PE:::hot
  TE:::hot

  classDef hot fill:#fff3b0,stroke:#111,stroke-width:2px,color:#111;
