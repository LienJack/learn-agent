flowchart TB
  M["Model\n只看到工具说明与 schema"] --> I["Tool Intent\n结构化请求"]
  I --> C["Tool Contract\n工具契约"]
  C --> V["Input Validation\n参数/路径/语义"]
  V --> P["Permission Runtime\nallow/ask/deny"]
  P --> X["Executor\n文件系统或 shell"]
  X --> O["Observation\n结构化结果"]
  O --> A["Audit Event\n可追踪事实"]
  O --> M

  subgraph Bundle["Local Tool Bundle"]
    C
    V
    P
    X
  end

  C:::hot
  P:::hot
  O:::hot

  classDef hot fill:#fff3b0,stroke:#111,stroke-width:2px,color:#111;
