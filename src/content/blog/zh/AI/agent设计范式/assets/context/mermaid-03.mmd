flowchart TB
  O["大工具结果<br/>read_file 30,000 行<br/>npm test 192KB 输出"] --> G{"超过单工具阈值<br/>或同一 message 总预算?"}
  G -- "否" --> I["原结果可 inline<br/>但仍记录 source"]
  G -- "是" --> P["完整结果持久化到 L3<br/>session/tool-results 或 artifact"]
  P --> V["生成稳定 preview<br/>路径 + 2KB 预览 / 截断尾部"]
  V --> F["按 tool_use_id 冻结替换决策<br/>后续每轮稳定复现"]
  F --> Q{"这份输出对下一步<br/>是否高价值?"}
  Q -- "否" --> K["L1 只保留 preview + raw_ref"]
  Q -- "是" --> C["压缩器读取完整或选定范围<br/>生成结构化 observation"]
  C --> B["L1 放高密度摘要<br/>failed_tests / stack / files / next_commands"]
  B --> M["模型继续推理"]
  K --> M
  I --> M
  M -. "需要精确原文时" .-> P

  classDef input fill:#eef2ff,stroke:#4c51bf,color:#1f245f,stroke-width:2px;
  classDef gate fill:#fff7ed,stroke:#c05621,color:#4a2308,stroke-width:2px;
  classDef store fill:#fef2f2,stroke:#c53030,color:#4a1212,stroke-width:2px;
  classDef context fill:#ecfdf5,stroke:#2f855a,color:#17351f,stroke-width:2px;
  class O,I,M input;
  class G,Q gate;
  class P,V,F store;
  class K,C,B context;
