flowchart TB
  Raw["Lossless Layer<br/>raw events / messages / tool outputs / artifacts"]
  Job["Compaction Job<br/>safe range + source refs"]
  SummaryOut["Summary<br/>给模型看的压缩上下文"]
  StatePatch["State Patch<br/>更新当前任务现场"]
  MemoryCandidate["Memory Candidate<br/>候选长期记忆"]
  Check["Compression Check<br/>goal / constraints / tool pairs / source refs"]
  Governance["Memory Governance<br/>scope / confidence / TTL"]
  ContextBuilderNode["ContextBuilder<br/>下一轮上下文编译"]
  Audit["Replay / Audit<br/>仍可回到原始事实"]

  Raw --> Job
  Job --> SummaryOut
  Job --> StatePatch
  Job --> MemoryCandidate
  SummaryOut --> Check
  StatePatch --> Check
  Check --> ContextBuilderNode
  MemoryCandidate --> Governance
  Raw -. "never overwritten" .-> Audit
  Audit -. "rebuild state" .-> StatePatch

  classDef raw fill:#eff6ff,stroke:#2563eb,color:#0f172a;
  classDef lossy fill:#fff7ed,stroke:#ea580c,color:#0f172a;
  classDef guard fill:#fef2f2,stroke:#dc2626,color:#0f172a;
  classDef output fill:#ecfdf5,stroke:#059669,color:#0f172a;
  class Raw,Audit raw;
  class Job,SummaryOut,StatePatch,MemoryCandidate lossy;
  class Check,Governance guard;
  class ContextBuilderNode output;
