flowchart TB
  A["原始音频 PCM"] --> B["音频编码器"]
  C["原始视频 RGB 或 YUV"] --> D["视频编码器"]
  B --> E["AAC MP3 Opus 等音频码流"]
  D --> F["H264 H265 VP9 AV1 等视频码流"]
  E --> G["音频解码器"]
  F --> H["视频解码器"]
  G --> I["PCM 或 AudioData"]
  H --> J["VideoFrame 或像素数据"]
  K["压缩依据"] --> B
  K --> D
  K --> K1["听觉和视觉冗余"]
  K --> K2["空间冗余和时间冗余"]
  K --> K3["码率 质量 延迟的取舍"]
