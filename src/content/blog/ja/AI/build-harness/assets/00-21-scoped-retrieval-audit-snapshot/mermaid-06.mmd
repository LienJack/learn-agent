flowchart TB
  subgraph "Retrieval Audit Snapshot"
    SC["Scope"]
    PL["Query Plan"]
    CA["候補者の統計"]
    SE["証拠の選択"]
    RJ["拒否理由"]
    PR["投影されたテキスト"]
    CM["参照マッピング"]
  end

  SE -.sourceRef.-> SRC["ソースバージョン"]
  PR -.artifactRef.-> ART["表示されるテキストアーティファクト"]
