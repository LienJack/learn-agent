flowchart TD
  B["buildQuery(state)\n组装本轮上下文"] --> M["model.generate()\n请求模型"]
  M --> P["parseResponse()\n解析返回"]
  P --> D{"包含 tool intent?"}
  D -- "否" --> F["final answer\n结束本轮任务"]
  D -- "是" --> V["validate intent\n校验工具名和参数"]
  V --> E["execute tool\n受控执行"]
  E --> R["make observation\n整理结果"]
  R --> A["append to messages\n写回状态"]
  A --> C["check budgets\n轮次/上下文/中断"]
  C --> B

  D:::hot
  R:::hot
  C:::hot

  classDef hot fill:#fff3b0,stroke:#111,stroke-width:2px,color:#111;
