flowchart LR
  U["用户目标\n修复测试"] --> F["Runtime Facade\n启动 run"]
  F --> C["Core Kernel\ncontracts / state / events"]
  C --> P["Model Provider\n真实大模型"]
  P --> ME["ModelEvent\ntext / tool_intent / final"]
  ME --> C
  C --> R["Registry\n工具与能力目录"]
  C --> EB["Event Bus\n事实日志"]
  C --> S["Conversation State\n当前现场"]
  C --> TR["Tool Runtime\n后续章节"]

  P -. "只返回事件" .-> ME
  P -. "不执行工具" .-> TR
  TR -. "执行权属于 runtime" .-> C

  C:::hot
  ME:::hot
  EB:::hot

  classDef hot fill:#fff3b0,stroke:#111,stroke-width:2px,color:#111;
