flowchart TB
  subgraph "Session Event Log"
    U["UserMessage"]
    I["ToolIntent"]
    P["PolicyDecision"]
    X["ToolExecution"]
    O["Observation"]
    C["Compaction"]
    V["Verification"]
  end

  subgraph "Artifact Store"
    L["テストログ"]
    D["ファイルの差分"]
    Q["モデル入力スナップショット"]
    R["ツールの生の結果"]
  end

  U --> I --> P --> X --> O --> C --> V
  X -.artifactRef.-> L
  X -.artifactRef.-> D
  O -.projectionRef.-> R
  C -.snapshotRef.-> Q

  classDef hot fill:#fff3c4,stroke:#d6a700,color:#222;
  class U,X,O hot;
