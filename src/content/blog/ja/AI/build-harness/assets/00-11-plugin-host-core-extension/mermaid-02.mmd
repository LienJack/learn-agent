flowchart TB
  subgraph EXT["外部プラグイン"]
    PM["プラグインマニフェスト名/バージョン/機能ステートメント"]
    PI["Plugin Implementation\nsetup/start/stop"]
  end

  subgraph HOST["Plugin Host"]
    LD["ローダーの検出と検証"]
    LC["ライフサイクルのロード/有効化/停止"]
    RG["レジストリ機能の登録"]
    HK["フックカーネルのブロックと監視"]
  end

  subgraph CORE["Core Kernel"]
    CT["Contracts\nProvider/Tool/Hook"]
    EV["イベントログの信頼できる情報源"]
    RT["Runtime\nLoop/Intent/Observe"]
  end

  PM --> LD
  PI --> LD
  LD --> LC
  LC --> RG
  RG --> CT
  HK --> RT
  RT --> EV
  HK --> EV

  LD:::hot
  RG:::hot
  HK:::hot

  classDef hot fill:#fff3b0,stroke:#111,stroke-width:2px,color:#111;
