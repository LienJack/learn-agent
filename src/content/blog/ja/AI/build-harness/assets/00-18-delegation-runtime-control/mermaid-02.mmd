flowchart LR
  PA["父 Agent\n提出委派意图"] --> DI["DelegateIntent\n任务、角色、边界"]
  DI --> V["Validate\n结构/范围/依赖"]
  V --> P["Permission\n工具与风险审批"]
  P --> S["Spawn\n启动受控子 Agent"]
  S --> R["Run\n隔离上下文内执行"]
  R --> O["Observation\n结构化结果"]
  O --> J["Join\n父 Agent 审阅合并"]
  J --> PA2["父 Agent\n继续主循环"]

  DI:::hot
  P:::hot
  J:::hot
  classDef hot fill:#fff3b0,stroke:#111,stroke-width:2px,color:#111;
