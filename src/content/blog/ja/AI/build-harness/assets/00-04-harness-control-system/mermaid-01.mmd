  H --> O["Observability\n日志与追踪"]
  H --> V["Verification\n验证与评估"]
  H --> G["Governance\n权限与治理"]

  E --> W["真实项目\n文件、命令、测试"]
  T --> W
  C --> A
  L --> A
  O --> V
  G --> E
  G --> T

  H:::hot
  G:::hot

