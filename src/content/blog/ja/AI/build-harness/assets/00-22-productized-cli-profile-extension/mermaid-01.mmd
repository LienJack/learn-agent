  PROF --> PR["Provider Resolver\n模型选择与降级"]
  PROF --> CAP["Capability Discovery\n本轮可见能力"]
  CAP --> LOOP["Agent Runtime\nloop/session/tool pipeline"]
  PR --> LOOP
  EXT --> CAP
  LOOP --> OUT["稳定输出协议\nTTY/JSON/Host Events"]

  PROF:::hot
  PR:::hot
  OUT:::hot

