flowchart LR
  REQ["モデルリクエストの内部リクエスト"] --> NEED["Capability Need\nstream/tool/context"]
  NEED --> PREF["プロファイルの優先順位と制限事項"]
  PREF --> RES{"プロバイダー リゾルバーの可用性/コスト/容量"}
  RES -- 「プライマリは使用可能です」--> PA["Provider A\nadapter"]
  RES -- 「プライマリは使用できません」--> FB["フォールバック チェーンは切り替えの理由を説明します"]
  FB --> PB["Provider B\nadapter"]
  PA --> EV["ModelEvent統合イベント"]
  PB --> EV
  EV --> CORE["コアランタイムの同じループ"]
  RES --> TRACE["トレースレコードの選択理由"]

  RES:::hot
  EV:::hot
  TRACE:::hot

  classDef hot fill:#fff3b0,stroke:#111,stroke-width:2px,color:#111;
