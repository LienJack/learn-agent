flowchart TB
  Root["root session<br/>user goal and initial scene"]
  Main["main path<br/>mainline execution"]
  BranchA["branch A<br/>explore option A"]
  BranchB["branch B<br/>explore option B"]
  Subagent["subagent task<br/>isolated research / verification"]
  Join["merge / compare<br/>return to mainline with evidence refs"]

  Root --> Main
  Root --> BranchA
  Root --> BranchB
  Root --> Subagent
  BranchA --> Join
  BranchB --> Join
  Subagent --> Join
  Join --> Main

  classDef root fill:#eff6ff,stroke:#2563eb,color:#0f172a;
  classDef branch fill:#fff7ed,stroke:#ea580c,color:#0f172a;
  classDef main fill:#ecfdf5,stroke:#059669,color:#0f172a;
  classDef join fill:#f5f3ff,stroke:#7c3aed,color:#0f172a;
  class Root root;
  class Main main;
  class BranchA,BranchB,Subagent branch;
  class Join join;
