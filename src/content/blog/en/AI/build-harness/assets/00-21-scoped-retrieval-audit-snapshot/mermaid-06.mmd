flowchart TB
  subgraph "Retrieval Audit Snapshot"
    SC["Scope"]
    PL["Query Plan"]
    CA["candidate statistics"]
    SE["Select evidence"]
    RJ["Reason for rejection"]
    PR["Projected text"]
    CM["Reference mapping"]
  end

  SE -.sourceRef.-> SRC["Source version"]
  PR -.artifactRef.-> ART["Visible text artifact"]
  CM -.citation.-> SRC
  SC --> PL --> CA --> SE --> PR
  RJ --> CA

  SC:::hot
  PR:::hot

  classDef hot fill:#fff3b0,stroke:#111,stroke-width:2px,color:#111;
