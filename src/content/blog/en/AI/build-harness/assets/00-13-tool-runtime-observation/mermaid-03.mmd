flowchart TB
  P["Permission Allow\n可执行"] --> C{"Concurrency\n并发安全吗"}
  C -->|safe| Q["Parallel Queue\n并发队列"]
  C -->|keyed| K{"Resource Key\n同资源冲突?"}
  C -->|exclusive| E["Serial Queue\n串行队列"]
  K -->|无冲突| Q
  K -->|有冲突| E
  Q --> B{"Long Running?\n长任务吗"}
  E --> B
  B -->|否| F["Foreground\n前台等待"]
  B -->|是| G["Backgroundable\n后台任务/进度"]
  F --> X["Execute\n执行"]
  G --> X

  C:::hot
  K:::hot
  B:::hot

  classDef hot fill:#fff3b0,stroke:#111,stroke-width:2px,color:#111;
