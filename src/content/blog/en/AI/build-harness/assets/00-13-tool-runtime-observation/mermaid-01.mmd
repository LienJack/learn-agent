flowchart LR
  I["Tool Intent model application"] --> R["Registry lookup tool"]
  R --> V["Validate structure/semantics"]
  V --> P{"Permission\nallow/ask/deny"}
  P -->|allow| S["Scheduler schedule"]
  P -->|ask| H["Human confirmation"]
  P -->|deny| N["Denied refused to observe"]
  H -->|agree| S
  H -->|reject| N
  S --> X["Sandbox controlled execution"]
  X --> Z["Normalize the results to normalize"]
  Z --> T["Truncate truncate/quote"]
  T --> O["Observation fact projection"]
  N --> O
  O --> A["Audit Event audit record"]
  O --> M["Next Model Turn"]

  V:::hot
  P:::hot
  O:::hot

  classDef hot fill:#fff3b0,stroke:#111,stroke-width:2px,color:#111;
