flowchart TB
  OUT["Tool Output\n原始输出"] --> OBS["Observation Event\n规范化观察"]
  OBS --> LOG["Session Log\n事实源"]
  LOG --> REDUCE["State Reducer\n折叠当前现场"]
  REDUCE --> STATE["State\n目标/预算/文件/错误"]
  STATE --> PROJECT["Context Projector\n投影本轮视野"]
  RULE["Rules\n系统和项目规则"] --> PROJECT
  MEM["Memory\n可复用经验"] --> PROJECT
  PROJECT --> INPUT["Model Input\n最终请求"]

  LOG:::hot
  PROJECT:::hot
  INPUT:::hot

  classDef hot fill:#fff3b0,stroke:#111,stroke-width:2px,color:#111;
