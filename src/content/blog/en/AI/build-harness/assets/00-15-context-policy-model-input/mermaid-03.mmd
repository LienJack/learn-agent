flowchart TB
  OUT["Tool Output raw output"] --> OBS["Observation Event Normalized Observation"]
  OBS --> LOG["Session Log Source of Truth"]
  LOG --> REDUCE["State Reducer collapses the current scene"]
  REDUCE --> STATE["State Goal/Budget/File/Error"]
  STATE --> PROJECT["Context Projector projects the epicycle field of view"]
  RULE["Rules system and project rules"] --> PROJECT
  MEM["Memory reusable experience"] --> PROJECT
  PROJECT --> INPUT["Model Input final request"]

  LOG:::hot
  PROJECT:::hot
  INPUT:::hot

  classDef hot fill:#fff3b0,stroke:#111,stroke-width:2px,color:#111;
