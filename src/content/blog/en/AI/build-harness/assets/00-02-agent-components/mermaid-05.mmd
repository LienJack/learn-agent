flowchart TB
  LOG["Session Log immutable event source of truth"] --> FOLD["State Reducer collapse event"]
  FOLD --> ST["State current task site"]
  ST --> CP["Context Projector selection, compression, isolation, sorting"]
  MEM["Memory Store cross-task experience"] --> CP
  DOC["Project Docs / Index External Knowledge"] --> CP
  CP --> INPUT["Model Input current round context"]
  INPUT --> MODEL["Model Provider model events"]
  MODEL --> LOOP["Runtime Decision Continue/Approve/Execute/End"]
  LOOP --> LOG

  LOG:::hot
  CP:::hot

  classDef hot fill:#fff3b0,stroke:#111,stroke-width:2px,color:#111;
