flowchart TB
  U["User Goal User Goal"] --> R["Runtime/Loop control flow"]
  R --> P["Model Provider only produces model events"]
  P --> E["Model Event\ntext / tool_intent / final"]
  E --> R
  R --> TR["Tool Runtime verification, permissions, execution, observation"]
  TR --> O["Observation structured results"]
