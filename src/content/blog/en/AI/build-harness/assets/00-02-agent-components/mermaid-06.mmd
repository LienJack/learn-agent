flowchart TD
  U["user goals"] --> QE["Runtime/QueryEngine session-level orchestration"]
  QE --> C["Context Builder builds the input of this round"]
  C --> M["Model output text or tool intent"]
  M --> D{"Have instrumental intentions?"}
  D -- "no" --> F["Final return result"]
  D -- "yes" --> P["Permission Gate permission/approval"]
  P --> T["Tool Runtime execution tool"]
  T --> S["Session State Record Observation"]
  S --> G["Guardrails budget/compression/interruption"]
  G --> C

  P:::hot
  S:::hot

  classDef hot fill:#fff3b0,stroke:#111,stroke-width:2px,color:#111;
