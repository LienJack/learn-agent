flowchart TB
  C["Candidate candidate memory"] --> SRC{"Is the source reliable?"}
  SRC -- "no" --> LOW["Downgrade confidence or reject"]
  SRC -- "yes" --> SCP{"Is the scope clear?"}
  SCP -- "no" --> ASK["Supplementary scope needs_review"]
  SCP -- "yes" --> TTL{"Is TTL required?"}
  TTL -- "yes" --> ADDTTL["Write expiration/review time"]
  TTL -- "no" --> CONFLICT{"Is there any conflict?"}
  ADDTTL --> CONFLICT
  CONFLICT -- "have" --> REVIEW["Review Gate merge/replace/reject"]
  CONFLICT -- "none" --> APPROVE{"Is the confidence level sufficient?"}
  APPROVE -- "no" --> PEND["Keep pending to wait for more evidence"]
  APPROVE -- "yes" --> STORE["Write to Governance Store"]

  REVIEW:::hot
  STORE:::hot

  classDef hot fill:#fff3b0,stroke:#111,stroke-width:2px,color:#111;
