flowchart LR
  STORE["Governance Store long term memory"] --> USE["Retrieval Usage Retrieval Usage"]
  USE --> SIGNAL["Signals hits/ignores/conflicts"]
  SIGNAL --> HEALTH["Health Check"]
  HEALTH --> DECIDE{"processing action"}
  DECIDE -- "still valid" --> KEEP["stay active"]
  DECIDE -- "Expired" --> EXP["mark expired"]
  DECIDE -- "conflict" --> REV["Enter review"]
  DECIDE -- "Can be merged" --> MERGE["merged version"]
  KEEP --> STORE
  EXP --> STORE
  REV --> STORE
  MERGE --> STORE

  HEALTH:::hot
  REV:::hot

  classDef hot fill:#fff3b0,stroke:#111,stroke-width:2px,color:#111;
