flowchart LR
  EV["Session Events User/Tool/Model"] --> EXT["Candidate Extractor candidate extraction"]
  EXT --> NORM["Normalize structured fields"]
  NORM --> LEDGER["Candidate Ledger Ledger to be managed"]
  LEDGER --> CHECK["Governance Checks Source/Scope/TTL/Conflict"]
  CHECK --> REVIEW{"Review Gate passed?"}
  REVIEW -- "pass" --> STORE["Governance Store long term memory"]
  REVIEW -- "Supplementary evidence" --> WAIT["Pending Evidence Waiting for verification"]
  REVIEW -- "reject" --> REJ["Rejected retention reason"]

  LEDGER:::hot
  CHECK:::hot

  classDef hot fill:#fff3b0,stroke:#111,stroke-width:2px,color:#111;
