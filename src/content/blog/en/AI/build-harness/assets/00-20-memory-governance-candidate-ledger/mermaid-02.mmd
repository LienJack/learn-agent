flowchart LR
  EV["Session Events\n用户/工具/模型"] --> EXT["Candidate Extractor\n候选提取"]
  EXT --> NORM["Normalize\n结构化字段"]
  NORM --> LEDGER["Candidate Ledger\n待治理账本"]
  LEDGER --> CHECK["Governance Checks\n来源/范围/TTL/冲突"]
  CHECK --> REVIEW{"Review Gate\n通过吗"}
  REVIEW -- "通过" --> STORE["Governance Store\n长期记忆"]
  REVIEW -- "补证据" --> WAIT["Pending Evidence\n等待验证"]
  REVIEW -- "拒绝" --> REJ["Rejected\n保留原因"]

  LEDGER:::hot
  CHECK:::hot

  classDef hot fill:#fff3b0,stroke:#111,stroke-width:2px,color:#111;
