flowchart TB
  LOG["Session Log fact events"] --> ST["State current site"]
  ST --> CTX["Context Epicycle horizon"]
  LOG --> CAND["Candidate Ledger candidate memory"]
  CAND --> GOV{"Governance governance check"}
  GOV -- "pass" --> STORE["Governance Store long term memory"]
  GOV -- "Need confirmation" --> REVIEW["Review Gate manual or policy review"]
  GOV -- "reject" --> ARCHIVE["Rejected / Expired leaves traces but does not inject"]
  STORE --> RET["Scoped Retrieval with bounded retrieval"]
  RET --> CTX

  CAND:::hot
  GOV:::hot

  classDef hot fill:#fff3b0,stroke:#111,stroke-width:2px,color:#111;
