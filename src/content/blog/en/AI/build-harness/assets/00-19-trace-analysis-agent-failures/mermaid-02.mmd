    E1["model.responded"]
    E2["tool.intent.created"]
    E3["permission.decided"]
    E4["tool.finished"]
    E5["observation.projected"]
    E6["verification.finished"]
  end

  subgraph "Trace View: Diagnostic Organization"
    G["Target"]
    C["context"]
    J["Model judgment"]
    I["instrumental intent"]
    P["Permission decisions"]
    X["Execution result"]
    O["Observe projection"]
    V["Verify conclusion"]
