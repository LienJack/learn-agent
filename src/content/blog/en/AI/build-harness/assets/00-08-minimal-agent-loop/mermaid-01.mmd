flowchart LR
  U["User Goal Fix failed tests"] --> S["State current site"]
  S --> T["Think to determine what is missing"]
  T --> A{"Act? Need tools?"}
  A -- "need" --> X["Tool read/search/test"]
  X --> O["Observe result backfill"]
  O --> S
  A -- "unnecessary" --> F["Final gives conclusion"]

  T:::hot
  O:::hot
  F:::done

  classDef hot fill:#fff3b0,stroke:#111,stroke-width:2px,color:#111;
  classDef done fill:#e8f5e9,stroke:#111,stroke-width:1.5px,color:#111;
