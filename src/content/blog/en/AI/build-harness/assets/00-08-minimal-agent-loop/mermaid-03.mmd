flowchart TD
  B["buildQuery(state) assembles the current round context"] --> M["model.generate() request model"]
  M --> P["parseResponse() parsing returns"]
  P --> D{"Contains tool intent?"}
  D -- "no" --> F["final answer ends this round of tasks"]
  D -- "yes" --> V["validate intent verification tool name and parameters"]
  V --> E["execute tool controlled execution"]
  E --> R["make observation organize the results"]
  R --> A["append to messages write back status"]
  A --> C["check budgets rounds/context/interruptions"]
  C --> B

  D:::hot
  R:::hot
  C:::hot

  classDef hot fill:#fff3b0,stroke:#111,stroke-width:2px,color:#111;
