flowchart TD
  L["Loop Tick ready for the next round"] --> A{"aborted?"}
  A -- "yes" --> S1["Stop user interruption"]
  A -- "no" --> B{"turnCount >= maxTurns?"}
  B -- "yes" --> S2["Stop rounds exhausted"]
  B -- "no" --> C{"budget exhausted?"}
  C -- "yes" --> S3["Stop budget exhausted"]
  C -- "no" --> M["Call Model"]
  M --> D{"final?"}
  D -- "yes" --> F["Finish output conclusion"]
  D -- "no" --> E{"tool intent valid?"}
  E -- "no" --> S4["Stop or Repair Invalid Intent"]
  E -- "yes" --> X["Execute Tool"]
  X --> O["Observe writes back status"]
  O --> L

  S2:::warn
  S3:::warn
  S4:::warn
  F:::done

  classDef warn fill:#ffe0b2,stroke:#111,stroke-width:1.5px,color:#111;
  classDef done fill:#e8f5e9,stroke:#111,stroke-width:1.5px,color:#111;
