flowchart LR
  R["Raw Tool Result\nstdout / file / error"] --> N["Normalize\n结构化字段"]
  N --> B["Budget\n截断大结果"]
  B --> O["Observation\n摘要 + 证据"]
  O --> P["Prompt Context\n下一轮可见"]
  O --> E["Event Log\n事实记录"]

  N:::hot
  O:::hot

  classDef hot fill:#fff3b0,stroke:#111,stroke-width:2px,color:#111;
