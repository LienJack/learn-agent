flowchart TB
  EL["Event Log Source of Truth"] --> P1["Projection: main context goal/status/next step"]
  EL --> P2["Projection: Subtask Summary Evidence/Scope/Assumptions"]
  EL --> P3["Projection: review context diff/plan/risk"]

  P1 --> PA["Parent Agent"]
  P2 --> SA["Sub-Agent isolation execution"]
  P3 --> RA["Reviewer independent inspection"]

  SA --> SR["Structured results"]
  RA --> RR["review comments"]

  SR --> EL
  RR --> EL
  EL --> J["Parent Agent Join combines facts instead of transcripts"]

  EL:::hot
  J:::hot
  classDef hot fill:#fff3b0,stroke:#111,stroke-width:2px,color:#111;
