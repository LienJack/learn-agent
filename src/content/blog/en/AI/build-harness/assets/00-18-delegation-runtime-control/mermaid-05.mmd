flowchart TD
  F["Subtask failure or exception"] --> K{"Failure type"}
  K --> V["Validation task package is illegal"]
  K --> C["Capability Insufficient ability/authority"]
  K --> R["Runtime timeout/crash"]
  K --> O["Contract output is unqualified"]
  K --> S["Semantic conclusion conflict"]

  V --> A1["Correct task package Re-propose delegation"]
  C --> A2["Apply for permission or assign read-only role"]
  R --> A3["Retry/Downgrade/Cancel"]
  O --> A4["Request structured rewrite or conservative takeover"]
  S --> A5["Parent Agent examines evidence and arbitrates when necessary"]

  A1 --> J["Parent Agent Join"]
  A2 --> J
  A3 --> J
  A4 --> J
  A5 --> J

  J:::hot
  classDef hot fill:#fff3b0,stroke:#111,stroke-width:2px,color:#111;
