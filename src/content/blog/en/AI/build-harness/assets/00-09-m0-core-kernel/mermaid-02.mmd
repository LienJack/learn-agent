flowchart TB
  subgraph UI["CLI / 上层入口"]
    CLI["命令行输入"]
    OUT["终端输出"]
  end

  subgraph K["M0 Core Kernel"]
    FC["Runtime Facade"]
    CT["Contracts"]
    RG["Registry"]
    EB["Event Bus"]
    ST["Conversation State"]
  end

  subgraph EXT["外部能力"]
    MP["Model Provider"]
    TT["Test Tool\n后续扩展"]
    FS["File / Shell\n后续扩展"]
  end

  CLI --> FC
  FC --> CT
  CT --> MP
  MP --> CT
  CT --> EB
  EB --> ST
  RG --> CT
  FC --> OUT

  TT -. "注册能力" .-> RG
  FS -. "注册能力" .-> RG

  K:::hot
  CT:::hot

  classDef hot fill:#fff3b0,stroke:#111,stroke-width:2px,color:#111;
