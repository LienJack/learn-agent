flowchart TB
  subgraph UI["CLI / upper level entrance"]
    CLI["Command line input"]
    OUT["Terminal output"]
  end

  subgraph K["M0 Core Kernel"]
    FC["Runtime Facade"]
    CT["Contracts"]
    RG["Registry"]
    EB["Event Bus"]
    ST["Conversation State"]
  end

  subgraph EXT["external capabilities"]
    MP["Model Provider"]
    TT["Test Tool subsequent extensions"]
    FS["File / Shell subsequent extensions"]
  end

  CLI --> FC
  FC --> CT
  CT --> MP
  MP --> CT
  CT --> EB
  EB --> ST
  RG --> CT
  FC --> OUT

  TT -. "Registration ability" .-> RG
  FS -. "Registration ability" .-> RG

  K:::hot
  CT:::hot

  classDef hot fill:#fff3b0,stroke:#111,stroke-width:2px,color:#111;
