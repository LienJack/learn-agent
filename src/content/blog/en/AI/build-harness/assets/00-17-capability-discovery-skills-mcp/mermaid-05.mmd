flowchart TD
  A["Task starts Fix test failure"] --> B["Basic tools can be found in Read/Grep/Bash"]
  B --> C{"Is the current evidence enough?"}
  C -- "enough" --> D["Continue local targeting"]
  C -- "not enough" --> E["ToolSearch search candidate capabilities"]
  E --> F["Candidate result MCP/Skill/Tool"]
  F --> G{"Do permissions and budget allow?"}
  G -- "no" --> H["Return unavailable observation"]
  G -- "yes" --> I["Join Visible Set"]
  I --> J["The model proposes an intent"]
  J --> K["Unified Tool Pipeline"]

  E:::hot
  G:::hot
  K:::hot

  classDef hot fill:#fff3b0,stroke:#111,stroke-width:2px,color:#111;
