flowchart TB
  S["Session State complete event facts"] --> CP["Context Policy selection and compression"]
  PR["Project Rules Project Rules"] --> CP
  MEM["Memory long-term preference"] --> CP
  OBS["Latest Observation Latest tool results"] --> CP

  CP --> MI["Model Input current round context"]
  MI --> M["Model determines the next step"]
  M --> INT["Intent tool or answer"]
  INT --> S

  CP:::hot
  MI:::hot

  classDef hot fill:#fff3b0,stroke:#111,stroke-width:2px,color:#111;
