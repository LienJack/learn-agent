flowchart LR
  M["Model tool intent"] --> S["Schema parameter verification"]
  S --> P{"Permission allowed?"}
  P -- "reject" --> D["Observation explains why"]
  P -- "Need confirmation" --> Q["User Approval pause and wait"]
  P -- "allow" --> R["Tool Runtime calls the tool"]
  R --> E["Execution real execution"]
  E --> O["Observation structured results"]
  O --> ST["Session event log"]
  ST --> C["Context next round of input"]

  P:::hot
  O:::hot

  classDef hot fill:#fff3b0,stroke:#111,stroke-width:2px,color:#111;
