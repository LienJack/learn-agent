flowchart LR
  M["Model\n工具意图"] --> S["Schema\n参数校验"]
  S --> P{"Permission\n允许吗"}
  P -- "拒绝" --> D["Observation\n说明原因"]
  P -- "需要确认" --> Q["User Approval\n暂停等待"]
