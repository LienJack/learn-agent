flowchart LR
  M["Model Output tool intent"] --> V["Validate parameter verification"]
  V --> P["Policy permission judgment"]
  P --> X["Execute controlled execution"]
  X --> R["Result real result"]
  R --> O["Observation backfill to the model"]
  O --> S["State update site"]

  P -->|deny / ask| U["User/Rule reject or approve"]
  U --> O

  M:::cold
  P:::hot
  O:::hot

  classDef hot fill:#fff3b0,stroke:#111,stroke-width:2px,color:#111;
  classDef cold fill:#e8f3ff,stroke:#111,stroke-width:1.5px,color:#111;
