flowchart TB
  EL["Session Event Log Source of truth: What happened"] --> ST["State Reducer collapses the current scene"]
  ST --> CTX["Context Builder current round model input"]
  EL --> UI["Transcript / UI narration for people to read"]
  EL --> EV["Eval Trace Trace for evaluation"]
  ST --> MEM["Memory Candidate can accumulate experience"]
  MEM --> KB["Long-term Memory cross-task knowledge"]

  CTX --> M["Model determines the next step"]
  M --> EL

  EL:::hot
  CTX:::hot

  classDef hot fill:#fff3b0,stroke:#111,stroke-width:2px,color:#111;
