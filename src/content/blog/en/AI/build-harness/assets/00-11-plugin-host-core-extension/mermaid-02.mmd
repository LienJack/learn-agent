flowchart TB
  subgraph EXT["外部插件"]
    PM["Plugin Manifest\n名称/版本/能力声明"]
    PI["Plugin Implementation\nsetup/start/stop"]
  end

  subgraph HOST["Plugin Host"]
    LD["Loader\n发现与校验"]
    LC["Lifecycle\n加载/启用/停止"]
    RG["Registry\n能力注册"]
    HK["Hook Kernel\n阻断与观察"]
  end

  subgraph CORE["Core Kernel"]
    CT["Contracts\nProvider/Tool/Hook"]
    EV["Event Log\n事实源"]
    RT["Runtime\nLoop/Intent/Observe"]
  end

  PM --> LD
  PI --> LD
  LD --> LC
  LC --> RG
  RG --> CT
  HK --> RT
  RT --> EV
  HK --> EV

  LD:::hot
  RG:::hot
  HK:::hot

  classDef hot fill:#fff3b0,stroke:#111,stroke-width:2px,color:#111;
