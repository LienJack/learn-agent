flowchart TB
  subgraph EXT["external plug-in"]
    PM["Plugin Manifest name/version/capability statement"]
    PI["Plugin Implementation\nsetup/start/stop"]
  end

  subgraph HOST["Plugin Host"]
    LD["Loader discovery and verification"]
    LC["Lifecycle load/enable/stop"]
    RG["Registry Capability Registration"]
    HK["Hook Kernel blocking and observation"]
  end

  subgraph CORE["Core Kernel"]
    CT["Contracts\nProvider/Tool/Hook"]
    EV["Event Log Source of Truth"]
    RT["Runtime\nLoop/Intent/Observe"]
  end

  PM --> LD
  PI --> LD
  LD --> LC
  LC --> RG
  RG --> CT
  HK --> RT
  RT --> EV
  HK --> EV

  LD:::hot
  RG:::hot
  HK:::hot

  classDef hot fill:#fff3b0,stroke:#111,stroke-width:2px,color:#111;
