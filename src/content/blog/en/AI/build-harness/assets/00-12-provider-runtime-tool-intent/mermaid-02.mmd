flowchart TB
  subgraph Provider["Provider protocol layer"]
    TC["Tool Call Vendor Original Format"]
    TD["Tool Delta parameter slicing"]
  end

  subgraph Core["Core semantic layer"]
    TI["ToolIntent Unified Action Proposal"]
    EV["Event enters the fact log"]
  end

  subgraph Runtime["Tool Runtime execution layer"]
    VA["Validate\nschema / policy"]
