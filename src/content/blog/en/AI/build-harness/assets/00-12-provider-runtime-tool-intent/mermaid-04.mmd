flowchart TD
  E["An error occurred"] --> K{"Where does the error come from?"}
  K -->|HTTP / SDK / stream| PE["ProviderError model calling layer"]
  K -->|tool intent parse| IE["IntentError intent parsing layer"]
  K -->|schema / policy| VE["ValidationError verification layer"]
  K -->|User denied/permission| AE["ApprovalEvent permission layer"]
  K -->|real tool fails| TE["ToolError execution layer"]

  PE --> R1["Retry / downgrade / end this round"]
  IE --> R2["Request the model to resend the intent"]
  VE --> R3["Reject and backfill reason"]
  AE --> R4["Wait for user or record rejection"]
  TE --> R5["Generate observation"]

  PE:::hot
  TE:::hot

  classDef hot fill:#fff3b0,stroke:#111,stroke-width:2px,color:#111;
