flowchart TB
  M["Model Output"] --> P["Parse Tool Intent"]
  P --> V["Validate"]
  V -->|ok| A["Approve"]
  V -->|fail| O1["Observation verification failed"]
  A -->|allow| X["Execute"]
  A -->|ask/deny| O2["Observation permission results"]
  X --> R["Result Policy truncate/save artifact"]
  R --> O3["Observation fact projection"]
  O1 --> N["Next Model Turn"]
  O2 --> N
  O3 --> N

  P:::hot
  A:::hot
  R:::hot

  classDef hot fill:#fff3b0,stroke:#111,stroke-width:2px,color:#111;
