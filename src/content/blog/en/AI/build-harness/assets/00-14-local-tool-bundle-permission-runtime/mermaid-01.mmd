flowchart LR
  U["User Goal Fix test failure"] --> L["Agent Loop"]
  L --> I["Tool Intent Model Proposal"]
  I --> R["Local Tool Bundle Local Tool Bundle"]
  R --> V["Validate structure and semantic verification"]
  V --> P{"Permission permission decision"}
  P -->|allow| E["Execute controlled execution"]
  P -->|ask| H["Human manual confirmation"]
  P -->|deny| D["Reject"]
  H -->|agree| E
  H -->|reject| D
  E --> O["Observation fact backfill"]
  D --> O
  O --> L

  R --> F["File\nRead/Edit/Write"]
  R --> S["Search\nGlob/Grep"]
  R --> B["Terminal\nBash"]

  R:::hot
  P:::hot
  E:::hot

  classDef hot fill:#fff3b0,stroke:#111,stroke-width:2px,color:#111;
