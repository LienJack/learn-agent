---
import { Image } from 'astro:assets';
import type { CollectionEntry } from 'astro:content';
import BaseHead from '../components/BaseHead.astro';
import FormattedDate from '../components/FormattedDate.astro';
import Header from '../components/Header.astro';
import { DEFAULT_LOCALE, type Locale } from '../i18n/config';
import { getHtmlLang, getMessages } from '../i18n/messages';
import { getPostSlug } from '../content/blog/utils';
import { localizePath } from '../i18n/utils';
import type { AlternateLink, JsonLdObject } from '../seo/metadata';
import type { BlogSeriesTopicSection } from '../components/blog/blog-index';

type HeadingLink = {
	depth: number;
	slug: string;
	text: string;
};

type TocSection = {
	slug: string;
	text: string;
	children: Array<{
		slug: string;
		text: string;
	}>;
};

type Props = CollectionEntry<'blog'>['data'] & {
	locale?: Locale;
	prevPost?: CollectionEntry<'blog'> | null;
	nextPost?: CollectionEntry<'blog'> | null;
	headings?: HeadingLink[];
	backHref?: string;
	topicSections?: BlogSeriesTopicSection[];
	seo?: {
		canonicalPath: string;
		alternates: AlternateLink[];
		structuredData: JsonLdObject[];
	};
};

const {
	title,
	description,
	pubDate,
	updatedDate,
	heroImage,
	locale = DEFAULT_LOCALE,
	prevPost = null,
	nextPost = null,
	headings = [],
	backHref = '/blog',
	topicSections = [],
	seo,
} = Astro.props;
const messages = getMessages(locale);
const topicIndexCopy = {
	zh: {
		label: '主题索引',
		title: '重复内容合并导航',
		summary: '本系列跨章节反复出现的概念已收束到下面的主题入口，点击可直接跳到对应章节的小节。',
	},
	en: {
		label: 'Topic index',
		title: 'Merged repeated concepts',
		summary: 'Repeated ideas in this series are grouped below and linked to the exact section.',
	},
	ja: {
		label: 'トピック索引',
		title: '重複内容の統合ナビ',
		summary: 'このシリーズで繰り返される概念をまとめ、該当セクションへ直接移動できます。',
	},
} satisfies Record<Locale, { label: string; title: string; summary: string }>;
const mediaViewer = {
	openLabel:
		locale === 'zh' ? '查看大图' : locale === 'ja' ? '画像を拡大' : 'Open full image',
	closeLabel:
		locale === 'zh' ? '关闭大图查看' : locale === 'ja' ? '拡大表示を閉じる' : 'Close full image',
	zoomInLabel: locale === 'zh' ? '放大图片' : locale === 'ja' ? '拡大する' : 'Zoom in',
	zoomOutLabel: locale === 'zh' ? '缩小图片' : locale === 'ja' ? '縮小する' : 'Zoom out',
	title:
		locale === 'zh' ? '正文图片查看层' : locale === 'ja' ? '本文画像ビューアー' : 'Article media viewer',
};

const tocSections = headings.reduce<TocSection[]>((sections, heading) => {
	if (heading.depth === 2) {
		sections.push({
			slug: heading.slug,
			text: heading.text,
			children: [],
		});
		return sections;
	}

	if (heading.depth === 3 && sections.length > 0) {
		sections[sections.length - 1].children.push({
			slug: heading.slug,
			text: heading.text,
		});
	}

	return sections;
}, []);
const resolveTopicHref = (href: string) =>
	href.startsWith('/blog/') ? localizePath(locale, href) : href;
---

<html lang={getHtmlLang(locale)}>
	<head>
		<BaseHead
			title={title}
			description={description}
			image={heroImage}
			locale={locale}
			pageType="article"
			canonicalPath={seo?.canonicalPath}
			alternates={seo?.alternates}
			structuredData={seo?.structuredData}
		/>
	</head>

	<body class="article-page">
		<Header />
		<main class="page-shell-wide">
			<article class="article-shell">
				<div class="article-hero">
					{heroImage && <Image width={1020} height={510} src={heroImage} alt="" />}
				</div>
				<div class="article-body">
					{
						tocSections.length > 0 && (
							<aside class="article-toc" aria-label="Table of contents">
								<div class="article-toc-inner">
									<p class="article-toc-eyebrow">{messages.article.onThisPage}</p>
									<nav class="article-toc-nav">
										<ol class="article-toc-list">
											{tocSections.map((section) => (
												<li>
													<a class="article-toc-link" href={`#${section.slug}`}>
														{section.text}
													</a>
													{
														section.children.length > 0 && (
															<ol class="article-toc-sublist">
																{section.children.map((child) => (
																	<li>
																		<a class="article-toc-sublink" href={`#${child.slug}`}>
																			{child.text}
																		</a>
																	</li>
																))}
															</ol>
														)
													}
												</li>
											))}
										</ol>
									</nav>
								</div>
							</aside>
						)
					}
					<div class="article-prose">
						<a class="article-back-link" href={localizePath(locale, backHref)}>
							<span aria-hidden="true">←</span>
							<span>{messages.article.backToBlog}</span>
						</a>
						<header class="article-header">
							<div class="article-meta">
								<span><FormattedDate date={pubDate} locale={locale} /></span>
								{
									updatedDate && (
										<span>{messages.article.updatedAt} <FormattedDate date={updatedDate} locale={locale} /></span>
									)
								}
							</div>
							<h1>{title}</h1>
							{description && <p class="article-description">{description}</p>}
						</header>
						{
							topicSections.length > 0 && (
								<section class="article-topic-index" aria-labelledby="article-topic-index-title">
									<div class="article-topic-index-heading">
										<p class="article-topic-index-label">{topicIndexCopy[locale].label}</p>
										<div class="article-topic-index-copy">
											<h2 id="article-topic-index-title">{topicIndexCopy[locale].title}</h2>
											<p>{topicIndexCopy[locale].summary}</p>
										</div>
									</div>
									<div class="article-topic-grid">
										{
											topicSections.map((topic) => (
												<article class="article-topic-card">
													<div class="article-topic-card-copy">
														<h3>{topic.title}</h3>
														{topic.description && <p>{topic.description}</p>}
													</div>
													<ul class="article-topic-link-list">
														{
															topic.links.map((link) => (
																<li>
																	<a class="article-topic-link" href={resolveTopicHref(link.href)}>
																		<span class="article-topic-link-label">{link.label}</span>
																		{link.note && <span class="article-topic-link-note">{link.note}</span>}
																	</a>
																</li>
															))
														}
													</ul>
												</article>
											))
										}
									</div>
								</section>
							)
						}
						<slot />
						{
							(prevPost || nextPost) && (
								<nav class="article-pagination" aria-label="Article pagination">
									{prevPost ? (
										<a class="article-pagination-card article-pagination-card-prev" href={localizePath(locale, `/blog/${getPostSlug(prevPost)}`)}>
											<span class="article-pagination-kicker">
												<span aria-hidden="true">←</span>
												<span>{messages.article.prevPost}</span>
											</span>
											<span class="article-pagination-title">{prevPost.data.title}</span>
											{prevPost.data.description && (
												<span class="article-pagination-description">{prevPost.data.description}</span>
											)}
										</a>
									) : (
										<div class="article-pagination-spacer" aria-hidden="true"></div>
									)}
									{nextPost ? (
										<a class="article-pagination-card article-pagination-card-next" href={localizePath(locale, `/blog/${getPostSlug(nextPost)}`)}>
											<span class="article-pagination-kicker">
												<span>{messages.article.nextPost}</span>
												<span aria-hidden="true">→</span>
											</span>
											<span class="article-pagination-title">{nextPost.data.title}</span>
											{nextPost.data.description && (
												<span class="article-pagination-description">{nextPost.data.description}</span>
											)}
										</a>
									) : (
										<div class="article-pagination-spacer" aria-hidden="true"></div>
									)}
								</nav>
							)
						}
					</div>
				</div>
			</article>
		</main>
		{
			tocSections.length > 0 && (
				<nav class="article-mobile-progress" aria-label={messages.article.readingProgress}>
					<div class="article-mobile-progress-inner">
						<p class="article-mobile-progress-label">{messages.article.readingProgress}</p>
						<ol class="article-mobile-progress-list">
							{tocSections.map((section) => (
								<li class="article-mobile-progress-item">
									<a
										class="article-mobile-progress-link"
										href={`#${section.slug}`}
										data-progress-target={section.slug}
										aria-label={section.text}
										title={section.text}
									>
										<span class="sr-only">{section.text}</span>
									</a>
								</li>
							))}
						</ol>
					</div>
				</nav>
			)
		}
		{
			tocSections.length > 0 && (
				<script is:inline>
					document.addEventListener('DOMContentLoaded', () => {
						const tocLinks = Array.from(document.querySelectorAll('.article-toc a'));
						const mobileProgressLinks = Array.from(
							document.querySelectorAll('.article-mobile-progress-link'),
						);
						const sections = tocLinks
							.map((link) => {
								const id = link.getAttribute('href')?.slice(1);
								if (!id) return null;
								const target = document.getElementById(id);
								if (!target) return null;
								return { link, target };
							})
							.filter(Boolean);

						if (sections.length === 0) return;

						const progressStorageKey = `article-reading-progress:${window.location.pathname}`;

						const readSavedHeadingId = () => {
							try {
								const rawProgress = window.localStorage.getItem(progressStorageKey);
								if (!rawProgress) return null;

								const progress = JSON.parse(rawProgress);
								return typeof progress?.headingId === 'string' ? progress.headingId : null;
							} catch {
								return null;
							}
						};

						const saveHeadingId = (id) => {
							try {
								window.localStorage.setItem(
									progressStorageKey,
									JSON.stringify({
										headingId: id,
										updatedAt: new Date().toISOString(),
									}),
								);
							} catch {
								// Ignore storage failures so reading behavior stays unchanged.
							}
						};

						const setActiveLink = (id, shouldSave = true) => {
							tocLinks.forEach((link) => {
								link.classList.toggle('is-active', link.getAttribute('href') === `#${id}`);
							});
							mobileProgressLinks.forEach((link) => {
								const isActive = link.dataset.progressTarget === id;
								link.classList.toggle('is-active', isActive);
								if (isActive) {
									link.setAttribute('aria-current', 'location');
								} else {
									link.removeAttribute('aria-current');
								}
							});

							if (shouldSave) {
								saveHeadingId(id);
							}
						};

						const restoreSavedProgress = () => {
							if (window.location.hash) return false;

							const savedHeadingId = readSavedHeadingId();
							if (!savedHeadingId) return false;

							const savedSection = sections.find((section) => section.target.id === savedHeadingId);
							if (!savedSection) return false;

							window.requestAnimationFrame(() => {
								savedSection.target.scrollIntoView({ block: 'start' });
								setActiveLink(savedHeadingId, false);
							});

							return true;
						};

						const observer = new IntersectionObserver(
							(entries) => {
								const visibleEntry = entries
									.filter((entry) => entry.isIntersecting)
									.sort((a, b) => a.boundingClientRect.top - b.boundingClientRect.top)[0];

								if (visibleEntry?.target?.id) {
									setActiveLink(visibleEntry.target.id);
								}
							},
							{
								rootMargin: '-20% 0% -65% 0%',
								threshold: [0, 1],
							},
						);

						sections.forEach((section) => observer.observe(section.target));
						if (!restoreSavedProgress()) {
							setActiveLink(sections[0].target.id, false);
						}
					});
				</script>
			)
		}
		<div
			class="article-media-viewer"
			data-article-media-viewer
			data-open-label={mediaViewer.openLabel}
			data-zoom-in-label={mediaViewer.zoomInLabel}
			data-zoom-out-label={mediaViewer.zoomOutLabel}
			aria-hidden="true"
		>
			<div
				class="article-media-viewer-panel"
				data-article-media-panel
				role="dialog"
				aria-modal="true"
				aria-label={mediaViewer.title}
			>
				<button
					class="article-media-viewer-close"
					type="button"
					data-article-media-close
					aria-label={mediaViewer.closeLabel}
				>
					<span aria-hidden="true">×</span>
				</button>
				<div class="article-media-viewer-toolbar" aria-label={mediaViewer.title}>
					<button
						class="article-media-viewer-zoom article-media-viewer-control"
						type="button"
						data-article-media-zoom-out
						aria-label={mediaViewer.zoomOutLabel}
					>
						<span aria-hidden="true">−</span>
					</button>
					<button
						class="article-media-viewer-zoom article-media-viewer-control"
						type="button"
						data-article-media-zoom-in
						aria-label={mediaViewer.zoomInLabel}
					>
						<span aria-hidden="true">+</span>
					</button>
				</div>
				<div class="article-media-viewer-viewport" data-article-media-viewport></div>
			</div>
		</div>
		<script>
			import '../scripts/blog-image-viewer.ts';
		</script>
	</body>
</html>
