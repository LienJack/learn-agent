#!/usr/bin/env node
import path from 'node:path';
import { loadDotEnv, parseArgs, printSummary, toRepoRelative, writeJson } from '../lib/common.mjs';
import { collectAssetExecution, reviewAssetPlan } from '../lib/assets.mjs';
import { inspectTranslatedSet } from '../lib/checks.mjs';
import { planOrdinaryImages } from '../lib/images.mjs';
import { planMermaidAssets } from '../lib/mermaid.mjs';
import { loadPipeline } from '../lib/pipelines.mjs';
import { createRun, finishRun, writeRunRecord } from '../lib/records.mjs';

loadDotEnv();

try {
	const { options } = parseArgs(process.argv.slice(2));
	if (options.help) {
		usage();
		process.exit(0);
	}
	if (!options.language) throw new Error('--language <en|ja> is required.');
	if (options.stage && !['mermaid', 'images'].includes(options.stage)) {
		throw new Error('--stage must be mermaid or images.');
	}
	await runAssetsCli(options);
} catch (error) {
	console.error(error instanceof Error ? error.message : String(error));
	process.exit(1);
}

async function runAssetsCli(options) {
	const pipeline = loadPipeline(options.pipeline);
	const stages = options.stage ? [options.stage] : ['mermaid', 'images'];
	const run = createRun({
		command: 'translate-assets',
		language: options.language,
		pipeline: pipeline.id,
		stage: stages.join('+'),
		inputs: stages,
	});
	const summary = { pipeline: pipeline.id, language: options.language, dryRun: options.dryRun, stages: {} };

	if (stages.includes('mermaid')) {
		summary.stages.mermaid = planMermaidAssets({
			pipeline,
			language: options.language,
			only: options.only,
			artifactDir: run.artifactDir,
		});
	}
	if (stages.includes('images')) {
		summary.stages.images = await planOrdinaryImages({ pipeline, language: options.language, only: options.only });
	}

	const blockers = Object.values(summary.stages).flatMap((stage) => stage.blockers || []);
	const warnings = Object.values(summary.stages).flatMap((stage) => stage.warnings || []);
	const review = reviewAssetPlan({
		pipeline,
		language: options.language,
		stages,
		summary,
		execution: !options.dryRun,
	});
	const artifactPath = path.join(run.artifactDir, `${options.language}-assets-plan.json`);
	const reviewPath = path.join(run.artifactDir, `${options.language}-assets-review.json`);
	writeJson(artifactPath, summary);
	writeJson(reviewPath, review);

	run.record.status = blockers.length || review.blockers.length ? 'blocked' : 'planned';
	run.record.blockers = unique([...blockers, ...review.blockers]);
	run.record.warnings = unique([...warnings, ...review.warnings]);
	run.record.checks.push({ name: 'asset-plan-review', status: review.status, checks: review.checks });
	run.record.artifacts.push(toRepoRelative(artifactPath), toRepoRelative(reviewPath));
	run.record.confirmation = {
		required: false,
		action: `Run real ${options.language} asset localization for ${stages.join(', ')}`,
		confirmed: !options.dryRun,
		method: 'automatic-plan-review',
	};
	writeRunRecord(run.recordPath, run.record);

	printSummary('Translation assets summary', [
		`Run: ${toRepoRelative(run.recordPath)}`,
		`Artifacts: ${toRepoRelative(run.artifactDir)}`,
		`Pipeline: ${pipeline.id}`,
		`Language: ${options.language}`,
		`Stages: ${stages.join(', ')}`,
		`Mermaid items: ${summary.stages.mermaid?.items.length ?? 0}`,
		`Ordinary image items: ${summary.stages.images?.items.length ?? 0}`,
		`Auto review: ${review.status}`,
		`Warnings: ${warnings.length ? warnings.join('; ') : 'none'}`,
		`Blockers: ${run.record.blockers.length ? run.record.blockers.join('; ') : 'none'}`,
	]);

	if (run.record.blockers.length || options.dryRun) {
		finishRun(run, run.record.blockers.length ? 'blocked' : 'planned');
		process.exit(run.record.blockers.length ? 1 : 0);
	}

	const execution = await collectAssetExecution({
		language: options.language,
		stages,
		summary,
		artifactDir: run.artifactDir,
	});
	const check = await inspectTranslatedSet({ pipeline, language: options.language });
	const checkPath = path.join(run.artifactDir, `${options.language}-post-assets-check.json`);
	writeJson(checkPath, check);

	run.record.status = execution.blockers.length || check.blockers.length ? 'blocked' : execution.status;
	run.record.blockers = unique([...run.record.blockers, ...execution.blockers, ...check.blockers]);
	run.record.warnings = unique([...run.record.warnings, ...execution.warnings, ...check.warnings]);
	run.record.checks.push(
		{ name: 'asset-execution', status: execution.status, results: execution.results },
		{ name: 'post-assets-translation-check', status: check.blockers.length ? 'blocked' : 'passed' },
	);
	run.record.artifacts.push(toRepoRelative(checkPath), ...execution.results.map((result) => result.artifact).filter(Boolean));
	writeRunRecord(run.recordPath, run.record);

	printSummary('Translation asset execution summary', [
		`Run: ${toRepoRelative(run.recordPath)}`,
		`Status: ${run.record.status}`,
		`Generated or accepted assets: ${execution.results.filter((result) => result.status === 'completed').length}`,
		`Review required: ${execution.results.filter((result) => result.status === 'review_required').length}`,
		`Warnings: ${run.record.warnings.length ? run.record.warnings.length : 'none'}`,
		`Blockers: ${run.record.blockers.length ? run.record.blockers.join('; ') : 'none'}`,
	]);
	finishRun(run, run.record.status);
	process.exit(run.record.blockers.length ? 1 : 0);
}

function unique(items) {
	return [...new Set(items.filter(Boolean))];
}

function usage() {
	console.log(`Usage:
  translate/bin/translate-assets --dry-run --language <en|ja> [--pipeline claude-code-series] [--stage mermaid|images] [--only target-file]

Behavior:
  - Mermaid stage extracts and plans Mermaid block rendering only.
  - Images stage plans ordinary PNG/JPG localization only.
  - Dry-run plans are automatically reviewed before any real execution.
  - Real execution writes prompt manifests, run records, and post-asset checks.`);
}
